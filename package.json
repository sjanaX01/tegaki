{
  "name": "@tegaki/root",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    ".",
    "packages/*"
  ],
  "scripts": {
    "start": "bun --filter tegaki-generator start",
    "dev": "bun --filter @tegaki/website dev",
    "build:website": "bun --filter @tegaki/website build",
    "compile": "bun --filter tegaki-generator compile",
    "test": "bun --filter '*' test",
    "typecheck": "tsgo",
    "lint": "biome lint",
    "format": "biome format",
    "check": "biome check",
    "fix": "biome check --write --unsafe",
    "checks": "bun check && bun typecheck && bun test",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "release": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@typescript/native-preview": "^7.0.0-dev.20260404.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
