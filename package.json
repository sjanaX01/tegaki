{
  "name": "tegaki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Create hand-written text animations",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/KurtGokhan/tegaki.git"
  },
  "bin": {
    "tegaki": "./dist/cli/index.js"
  },
  "imports": {
    "#*": "./*"
  },
  "license": "MIT",
  "author": {
    "name": "Gokhan Kurt",
    "email": "krtgkn@gmail.com",
    "url": "https://gkurt.com"
  },
  "files": [
    "dist/",
    "media/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "bun src/cli/index.ts",
    "dev": "bun serve",
    "serve": "bun --watch src/server.ts",
    "compile": "bun build --compile --minify --outfile dist src/cli/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format",
    "check": "biome check",
    "fix": "biome check --write --unsafe",
    "checks": "bun check && bun typecheck && bun test",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.26.4",
    "@chenglou/pretext": "^0.0.2",
    "bun-plugin-tailwind": "^0.1.2",
    "d3-delaunay": "^6.0.4",
    "fflate": "^0.8.2",
    "opentype.js": "^1.3.4",
    "padrone": "^1.7.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/bun": "^1.3.11",
    "@types/d3-delaunay": "^6.0.4",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
